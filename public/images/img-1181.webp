body { border-top: none !important; }

/* Search button 'Search' text was overflowing its background at any
   readable font-size (the box was only ever sized for an icon, not a
   6-letter word). Hide the text and show a magnifying-glass icon instead,
   keeping the button's original width so it never disturbs the input's
   layout again. */
@media (max-width: 1024px) {
  input.search-submit {
    color: transparent !important;
    font-size: 0 !important;
    background-image: url("data:image/svg+xml;charset=UTF-8,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22white%22 stroke-width=%223%22%3E%3Ccircle cx=%2211%22 cy=%2211%22 r=%227%22/%3E%3Cline x1=%2221%22 y1=%2221%22 x2=%2216.65%22 y2=%2216.65%22/%3E%3C/svg%3E") !important;
    background-repeat: no-repeat !important;
    background-position: center !important;
    background-size: 20px 20px !important;
  }
}

/* The Post Grid widget's loading spinner (#bottom-script-loader) never
   gets dismissed by its own JS after the posts finish rendering
   server-side, leaving a permanent spinner overlaid on already-loaded
   content. The posts render fine without it, so hide it outright. */
.bottom-script-loader { display: none !important; }</style><style class="wp-fonts-local">@font-face{ font-family:Inter;font-style:normal;font-weight:300 900;font-display:swap;src:url('https://championsreviews.com/wp-content/plugins/woocommerce/assets/fonts/Inter-VariableFont_slnt,wght.woff2') format('woff2');font-stretch:normal; }
