\"]\n            }\n        ];\n\n        // Function to generate star rating HTML\n        function generateStars(rating) {\n            if (!rating || rating === \"\") return '<span class=\"empty-rating\">No ratings</span>';\n            \n            const numericRating = parseFloat(rating);\n            let starsHTML = '';\n            \n            // Full stars\n            for (let i = 1; i <= 5; i++) {\n                if (i <= Math.floor(numericRating)) {\n                    starsHTML += '<i class=\"fas fa-star\"></i>';\n                } else if (i === Math.ceil(numericRating) && numericRating % 1 >= 0.5) {\n                    starsHTML += '<i class=\"fas fa-star-half-alt\"></i>';\n                } else {\n                    starsHTML += '<i class=\"far fa-star\"></i>';\n                }\n            }\n            \n            return starsHTML;\n        }\n\n        // Function to format delivery date display\n        function formatDeliveryDate(date) {\n            if (!date || date === \"\") return \"Delivery date varies\";\n            return `Delivery: ${date}`;\n        }\n\n        // Function to shorten product names for display\n        function shortenProductName(name, maxLength = 80) {\n            if (name.length <= maxLength) return name;\n            return name.substring(0, maxLength) + \"...\";\n        }\n\n        // Function to generate feature list HTML\n        function generateFeatureList(features) {\n            if (!features || features.length === 0) return \"\";\n            \n            let listHTML = '<ul class=\"feature-list\">';\n            features.slice(0, 4).forEach(feature => {\n                listHTML += `<li>${feature}</li>`;\n            });\n            \n            if (features.length > 4) {\n                listHTML += `<li>+${features.length - 4} more features</li>`;\n            }\n            \n            listHTML += '</ul>';\n            return listHTML;\n        }\n\n        // Render products to the page\n        const productContainer = document.getElementById('product-container');\n        \n        products.forEach(product => {\n            const productCard = document.createElement('div');\n            productCard.className = 'product-card';\n            \n            productCard.innerHTML = `\n                <div class=\"product-image\">\n                    <img decoding=\"async\" src=\"${product.image}\" alt=\"${product.name}\" loading=\"lazy\">\n                </div>\n                <div class=\"product-info\">\n                    <h3 class=\"product-title\">${shortenProductName(product.name)}</h3>\n                    <div class=\"product-price\">$${product.price}</div>\n                    <div class=\"product-features\">\n                        ${generateFeatureList(product.features)}\n                    </div>\n                    <div class=\"product-rating\">\n                        <div class=\"stars\">${generateStars(product.rating)}</div>\n                        <span class=\"rating-value\">${product.rating || '--'}</span>\n                        <span class=\"rating-count\">(${product.ratingsCount || '0'} ratings)</span>\n                    </div>\n                    <div class=\"product-meta\">\n                        <span class=\"delivery-date\">${formatDeliveryDate(product.deliveryDate)}</span>\n                    </div>\n                    <div class=\"product-actions\">\n                        <a href=\"${product.url}\" target=\"_blank\" class=\"btn btn-primary\">View on Amazon</a>\n                        <a href=\"${product.url}\" target=\"_blank\" class=\"btn btn-secondary\">More Details</a>\n                    </div>\n                </div>\n            `;\n            \n            productContainer.appendChild(productCard);\n        });\n\n        // Add note about more products\n        const noteElement = document.createElement('div');\n        noteElement.style.cssText = 'text-align: center; margin: 40px 0; color: 