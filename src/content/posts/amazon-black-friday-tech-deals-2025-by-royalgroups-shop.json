 \"Bose QuietComfort Headphones - Wireless Bluetooth Headphones, Active Over Ear Noise Cancelling and Mic, USB-C Charging, Deep Bass, Up to 24 Hours of Playtime, Black\",\n                brand: \"Bose\",\n                stars: 4.5,\n                reviewCount: 15213,\n                thumbnail: \"https://m.media-amazon.com/images/I/51f7KKP25PL._AC_SY300_SX300_QL70_FMwebp_.jpg\",\n                category: \"Electronics > Headphones, Earbuds & Accessories > Headphones & Earbuds > Over-Ear Headphones\",\n                price: \"$199.00\",\n                url: \"https://www.amazon.com/dp/B0CCZ26B5V?tag=skymaxx0e-20\"\n            },\n            {\n                description: \"JBL Charge 6 - Portable Waterproof & Drop-Proof Bluetooth Speaker, Bold Pro Sound with AI Sound Boost, 28Hrs of Playtime, Built-in powerbank & Comes with a Sturdy/Removable Carrying Strap (Blue)\",\n                brand: \"JBL\",\n                stars: 4.7,\n                reviewCount: 1985,\n                thumbnail: \"https://m.media-amazon.com/images/I/8179N0kJ2QL._AC_SY300_SX300_QL70_FMwebp_.jpg\",\n                category: \"Electronics > Portable Audio & Video > Portable Speakers & Docks > Portable Bluetooth Speakers\",\n                price: \"$129.95\",\n                url: \"https://www.amazon.com/dp/B0DN35M7S9?tag=skymaxx0e-20\"\n            },\n            {\n                description: \"Sony WH-1000XM5 Premium Noise Canceling Headphones, Auto NC Optimizer, 30-Hour Battery, Alexa Voice Control, Black\",\n                brand: \"Sony\",\n                stars: 4.2,\n                reviewCount: 18371,\n                thumbnail: \"https://m.media-amazon.com/images/I/51aXvjzcukL._AC_SY300_SX300_QL70_FMwebp_.jpg\",\n                category: \"Electronics > Headphones, Earbuds & Accessories > Headphones & Earbuds > Over-Ear Headphones\",\n                price: \"$248.00\",\n                url: \"https://www.amazon.com/dp/B09XS7JWHH?tag=skymaxx0e-20\"\n            },\n            {\n                description: \"Canon EOS R50 Mirrorless Camera RF-S18-45mm F4.5-6.3 is STM Lens Kit, 24.2 Megapixel CMOS (APS-C) Sensor, 4K Video, Hybrid Camera, Photo and Video, Vlogging, Content Creator, RF Mount, Black\",\n                brand: \"Canon\",\n                stars: 4.7,\n                reviewCount: 1600,\n                thumbnail: \"https://m.media-amazon.com/images/I/71ANGtyZRzL._AC_SX300_SY300_QL70_FMwebp_.jpg\",\n                category: \"Electronics > Camera & Photo > Digital Cameras > Mirrorless Cameras\",\n                price: \"$819.00\",\n                url: \"https://www.amazon.com/dp/B0BTTV6CT1?tag=skymaxx0e-20\"\n            },\n            {\n                description: \"Sony BRAVIA 5 65 Inch TV, Mini LED, 4K Smart Google TV, XR Processor with AI Technology,120hz Television with Dolby Vision/Atmos, Exclusive Features for PlayStation®5, K-65XR50, 2025 Model\",\n                brand: \"Sony\",\n                stars: 4.4,\n                reviewCount: 102,\n                thumbnail: \"https://m.media-amazon.com/images/I/716M5in9SnL._AC_SX300_SY300_QL70_FMwebp_.jpg\",\n                category: \"Electronics > Television & Video > Televisions > LED & LCD TVs\",\n                price: \"$998.00\",\n                url: \"https://www.amazon.com/dp/B0DYK9LY1Z?tag=skymaxx0e-20\"\n            },\n            {\n                description: \"DJI Mini 4K Fly More Combo, Drone with 4K UHD Camera for Adults, Under 249 g, 3-Axis Gimbal Stabilization, 10km Video Transmission, Auto Return, 3 Batteries for 93-Min Max Flight Time, QuickShots\",\n                brand: \"DJI\",\n                stars: 4.5,\n                reviewCount: 18754,\n                thumbnail: \"https://m.media-amazon.com/images/I/61HkkKG3cVL._AC_SY300_SX300_QL70_FMwebp_.jpg\",\n                category: \"Toys & Games > Remote & App Controlled Vehicles & Parts > Quadcopters & Multirotors\",\n                price: \"$459.48\",\n                url: \"https://www.amazon.com/dp/B0CXJCXN17?tag=skymaxx0e-20\"\n            },\n            {\n                description: \"Panasonic LUMIX G7 4K Digital Camera, with LUMIX G VARIO 14-42mm Mega O.I.S. Lens, 16 Megapixel Mirrorless Camera, 3-Inch LCD, DMC-G7KK (Black)\",\n                brand: \"Panasonic\",\n                stars: 4.5,\n                reviewCount: 1995,\n                thumbnail: \"https://m.media-amazon.com/images/I/611l2ooQReL._AC_SY300_SX300_QL70_FMwebp_.jpg\",\n                category: \"Electronics > Camera & Photo > Digital Cameras > Mirrorless Cameras\",\n                price: \"$697.99\",\n                url: \"https://www.amazon.com/dp/B00X409PQS?tag=skymaxx0e-20\"\n            }\n        ];\n\n        // Function to generate star rating HTML\n        function generateStars(rating) {\n            const fullStars = Math.floor(rating);\n            const halfStar = rating % 1 >= 0.5;\n            let starsHTML = '';\n            \n            for (let i = 0; i < fullStars; i++) {\n                starsHTML += '★';\n            }\n            \n            if (halfStar) {\n                starsHTML += '☆';\n            }\n            \n            return starsHTML;\n        }\n\n        // Function to extract unique brands and categories\n        function extractFilters() {\n            const brands = new Set();\n            const categories = new Set();\n            \n            products.forEach(product => {\n                brands.add(product.brand);\n                if (product.category) {\n                    // Split the category string and get the main category\n                    const mainCategory = product.category.split('>')[0].trim();\n                    categories.add(mainCategory);\n                }\n            });\n            \n            // Populate brand filter\n            const brandFilter = document.getElementById('brand-filter');\n            Array.from(brands).sort().forEach(brand => {\n                const option = document.createElement('option');\n                option.value = brand;\n                option.textContent = brand;\n                brandFilter.appendChild(option);\n            });\n            \n            // Populate category filter\n            const categoryFilter = document.getElementById('category-filter');\n            Array.from(categories).sort().forEach(category => {\n                const option = document.createElement('option');\n                option.value = category;\n                option.textContent = category;\n                categoryFilter.appendChild(option);\n            });\n        }\n\n        // Function to convert price string to number\n        function priceToNumber(priceStr) {\n            return parseFloat(priceStr.replace(/[$,]/g, ''));\n        }\n\n        // Function to filter products\n        function filterProducts() {\n            const brandFilter = document.getElementById('brand-filter').value;\n            const categoryFilter = document.getElementById('category-filter').value;\n            const priceFilter = document.getElementById('price-filter').value;\n            const starsFilter = document.getElementById('stars-filter').value;\n            const reviewsFilter = document.getElementById('reviews-filter').value;\n            \n            const filteredProducts = products.filter(product => {\n                // Brand filter\n                if (brandFilter !== 'all' && product.brand !== brandFilter) {\n                    return false;\n                }\n                \n                // Category filter\n                if (categoryFilter !== 'all') {\n                    if (!product.category || !product.category.includes(categoryFilter)) {\n                        return false;\n                    }\n                }\n                \n                // Price filter\n                if (priceFilter !== 'all') {\n                    const price = priceToNumber(product.price);\n                    \n                    switch(priceFilter) {\n                        case '0-100':\n                            if (price >= 100) return false;\n                            break;\n                        case '100-200':\n                            if (price < 100 || price >= 200) return false;\n                            break;\n                        case '200-500':\n                            if (price < 200 || price >= 500) return false;\n                            break;\n                        case '500-1000':\n                            if (price < 500 || price >= 1000) return false;\n                            break;\n                        case '1000+':\n                            if (price < 1000) return false;\n                            break;\n                    }\n                }\n                \n                // Stars filter\n                if (starsFilter !== 'all') {\n                    const minStars = parseFloat(starsFilter);\n                    if (product.stars < minStars) {\n                        return false;\n                    }\n                }\n                \n                // Reviews filter\n                if (reviewsFilter !== 'all') {\n                    const minReviews = parseInt(reviewsFilter);\n                    if (product.reviewCount < minReviews) {\n                        return false;\n                    }\n                }\n                \n                return true;\n            });\n            \n            return filteredProducts;\n        }\n\n        // Function to display products\n        function displayProducts(productsToShow) {\n            const productsGrid = document.getElementById('products-grid');\n            productsGrid.innerHTML = '';\n            \n            productsToShow.forEach(product => {\n                const productCard = document.createElement('div');\n                productCard.className = 'product-card';\n                \n                // Format review count with commas\n                const formattedReviewCount = product.reviewCount.toLocaleString();\n                \n                productCard.innerHTML = `\n                    <img decoding=\"async\" src=\"${product.thumbnail}\" alt=\"${product.description}\" class=\"product-image\">\n                    <div class=\"product-info\">\n                        <div class=\"product-brand\">${product.brand}</div>\n                        <h3 class=\"product-title\">${product.description}</h3>\n                        <div class=\"product-rating\">\n                            <span class=\"stars\">${generateStars(product.stars)}</span>\n                            <span class=\"rating-count\">${product.stars} (${formattedReviewCount} reviews)</span>\n                        </div>\n                        <div class=\"product-price\">${product.price}</div>\n                        ${product.category ? `<div class=\"product-category\">${product.category}</div>` : ''}\n                        <a href=\"${product.url}\" target=\"_blank\" class=\"buy-button\">Buy on Amazon</a>\n                    </div>\n                `;\n                \n                productsGrid.appendChild(productCard);\n            });\n            \n            // Update results count\n            const resultsCount = document.getElementById('results-count');\n            resultsCount.textContent = `Showing ${productsToShow.length} of ${products.length} products`;\n        }\n\n        // Function to clear filters\n        function clearFilters() {\n            document.getElementById('brand-filter').value = 'all';\n            document.getElementById('category-filter').value = 'all';\n            document.getElementById('price-filter').value = 'all';\n            document.getElementById('stars-filter').value = 'all';\n            document.getElementById('reviews-filter').value = 'all';\n            displayProducts(products);\n        }\n\n        // Initialize the page\n        document.addEventListener('DOMContentLoaded', function() {\n            extractFilters();\n            displayProducts(products);\n            \n            // Add event listeners\n            document.getElementById('apply-filters').addEventListener('click', function() {\n                const filteredProducts = filterProducts();\n                displayProducts(filteredProducts);\n            });\n            \n            document.getElementById('clear-filters').addEventListener('click', clearFilters);\n        });\n    </script>\n</body>\n</html>\n\n\n\n<p class=\"wp-block-paragraph\"></p>\n"
}