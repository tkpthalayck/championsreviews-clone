---
import { BASE as base } from '../lib/base';
interface Props {
  slug: string;
  title: string;
  excerpt: string;
  date: string;
  featuredImage: string | null;
  categories: string[];
}
const { slug, title, excerpt, date, featuredImage, categories } = Astro.props;
const formattedDate = new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<a href={`${base}reviews/${slug}/`} class="group flex flex-col rounded-2xl border border-gray-200 bg-white overflow-hidden hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200">
  <div class="aspect-[16/10] overflow-hidden bg-gray-100">
    {featuredImage && (
      <img
        src={`${base}${featuredImage.replace(/^\//, '')}`}
        alt={title}
        loading="lazy"
        decoding="async"
        width="480"
        height="300"
        class="w-full h-full object-contain p-4 group-hover:scale-105 transition-transform duration-300"
      />
    )}
  </div>
  <div class="flex flex-col flex-1 p-5">
    {categories[0] && (
      <span class="text-xs font-semibold uppercase tracking-wide text-[--color-brand-purple]">{categories[0]}</span>
    )}
    <h3 class="mt-1.5 font-bold text-gray-900 leading-snug line-clamp-2 group-hover:text-[--color-brand-purple] transition-colors">{title}</h3>
    <p class="mt-2 text-sm text-gray-600 line-clamp-2 flex-1">{excerpt}</p>
    <time datetime={date} class="mt-3 text-xs text-gray-400">{formattedDate}</time>
  </div>
</a>
