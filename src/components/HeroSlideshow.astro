---
import { BASE as base } from '../lib/base';

interface Props {
  posts: {
    data: {
      slug: string;
      title: string;
      excerpt: string;
      featuredImage: string | null;
      categories: string[];
    };
  }[];
  id: string;
}
const { posts, id } = Astro.props;
---

<div id={id} class="hero-slideshow relative overflow-hidden rounded-2xl bg-gray-900">
  <div class="relative h-[320px] sm:h-[420px] lg:h-[500px]">
    {posts.map((post, i) => (
      <a
        href={`${base}reviews/${post.data.slug}/`}
        class="hero-slide absolute inset-0 transition-opacity duration-700 ease-in-out"
        data-index={i}
        style={i === 0 ? undefined : 'opacity:0'}
        aria-hidden={i === 0 ? 'false' : 'true'}
      >
        {post.data.featuredImage && (
          <img
            src={/^https?:\/\//.test(post.data.featuredImage) ? post.data.featuredImage : `${base}${post.data.featuredImage.replace(/^\//, '')}`}
            alt={post.data.title}
            loading={i === 0 ? 'eager' : 'lazy'}
            decoding="async"
            class="h-full w-full object-cover"
          />
        )}
        <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/30 to-transparent"></div>
        <div class="absolute inset-x-0 bottom-0 p-6 sm:p-10 text-white">
          {post.data.categories[0] && (
            <span class="inline-block rounded-full bg-[--color-brand-gold] px-3 py-1 text-xs font-semibold text-gray-900">{post.data.categories[0]}</span>
          )}
          <h2 class="mt-3 max-w-2xl text-xl sm:text-3xl font-extrabold leading-tight line-clamp-2">{post.data.title}</h2>
          <p class="mt-2 hidden max-w-xl text-sm text-gray-200 line-clamp-2 sm:block">{post.data.excerpt}</p>
        </div>
      </a>
    ))}
  </div>

  <button type="button" data-hero-prev={id} aria-label="Previous slide" class="absolute left-3 top-1/2 -translate-y-1/2 flex h-9 w-9 sm:h-10 sm:w-10 items-center justify-center rounded-full bg-white/20 text-white backdrop-blur hover:bg-white/30 transition-colors">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
  </button>
  <button type="button" data-hero-next={id} aria-label="Next slide" class="absolute right-3 top-1/2 -translate-y-1/2 flex h-9 w-9 sm:h-10 sm:w-10 items-center justify-center rounded-full bg-white/20 text-white backdrop-blur hover:bg-white/30 transition-colors">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
  </button>

  <div class="absolute bottom-4 right-4 sm:right-6 flex gap-2">
    {posts.map((_, i) => (
      <button
        type="button"
        data-hero-dot={id}
        data-slide-to={i}
        aria-label={`Go to slide ${i + 1}`}
        class="hero-dot h-2 w-2 rounded-full bg-white/40 transition-colors hover:bg-white/70"
        data-active={i === 0 ? 'true' : 'false'}
      />
    ))}
  </div>
</div>

<script>
  const AUTO_ADVANCE_MS = 5500;

  for (const root of document.querySelectorAll<HTMLElement>('.hero-slideshow')) {
    const slides = root.querySelectorAll<HTMLElement>('.hero-slide');
    if (slides.length === 0) continue;

    const id = root.id;
    const dots = document.querySelectorAll<HTMLButtonElement>(`[data-hero-dot="${id}"]`);
    const prevBtn = document.querySelector<HTMLButtonElement>(`[data-hero-prev="${id}"]`);
    const nextBtn = document.querySelector<HTMLButtonElement>(`[data-hero-next="${id}"]`);
    if (!dots.length && !prevBtn && !nextBtn) continue;

    let current = 0;
    let timer: ReturnType<typeof setInterval> | undefined;

    function show(index: number) {
      current = (index + slides.length) % slides.length;
      slides.forEach((slide, i) => {
        const active = i === current;
        slide.style.opacity = active ? '1' : '0';
        slide.setAttribute('aria-hidden', active ? 'false' : 'true');
      });
      dots.forEach((dot, i) => dot.setAttribute('data-active', String(i === current)));
    }

    function start() {
      stop();
      timer = setInterval(() => show(current + 1), AUTO_ADVANCE_MS);
    }
    function stop() {
      if (timer) clearInterval(timer);
    }

    prevBtn?.addEventListener('click', () => { show(current - 1); start(); });
    nextBtn?.addEventListener('click', () => { show(current + 1); start(); });
    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        show(Number(dot.dataset.slideTo));
        start();
      });
    });
    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', start);

    start();
  }
</script>
