---
import { BASE as base } from '../lib/base';
const year = new Date().getFullYear();
const columns = [
  {
    title: 'Explore',
    links: [
      { label: 'Home', href: `${base}` },
      { label: 'All Posts', href: `${base}reviews/` },
      { label: 'Buying Guides', href: `${base}guides/` },
      { label: 'Search', href: `${base}search/` },
    ],
  },
  {
    title: 'Company',
    links: [
      { label: 'About Us', href: `${base}about-us/` },
      { label: 'Privacy Policy', href: `${base}privacy-policy/` },
      { label: 'Terms of Service', href: `${base}terms-of-service/` },
      { label: 'Contacts', href: `${base}contacts/` },
    ],
  },
];
---

<footer class="mt-16 border-t border-gray-200 bg-gray-50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8">
      <div class="md:col-span-2">
        <p class="font-extrabold text-lg text-[--color-brand-purple-dark]">ChampionsReview<span class="text-[--color-brand-purple]">.Com</span></p>
        <p class="mt-2 text-sm text-gray-600 max-w-sm">Discover the best picks from Amazon, Walmart & more — bringing you the best of global online deal info.</p>
        <div class="mt-4">
          <a href="https://championsreviews.com/#subscribe" class="inline-block rounded-lg bg-[--color-brand-blue] px-5 py-2.5 text-sm font-semibold text-white hover:opacity-90 transition-opacity">Subscribe for updates</a>
        </div>
      </div>
      {columns.map((col) => (
        <div>
          <h3 class="text-sm font-semibold text-gray-900">{col.title}</h3>
          <ul class="mt-3 space-y-2">
            {col.links.map((link) => (
              <li><a href={link.href} class="text-sm text-gray-600 hover:text-[--color-brand-purple]">{link.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-between gap-4 border-t border-gray-200 pt-6">
      <p class="text-xs text-gray-500">&copy; {year} Champions Reviews | All Rights Reserved</p>
      <div class="flex items-center gap-4">
        <a href="https://www.facebook.com/" aria-label="Facebook" class="text-gray-400 hover:text-[--color-brand-purple]" rel="noopener noreferrer" target="_blank">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.6 9.9v-7H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.4h-1.2c-1.2 0-1.6.8-1.6 1.6V12h2.8l-.4 2.9h-2.4v7A10 10 0 0 0 22 12"/></svg>
        </a>
        <a href="https://x.com/" aria-label="X" class="text-gray-400 hover:text-[--color-brand-purple]" rel="noopener noreferrer" target="_blank">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 23 24" fill="currentColor"><path d="M13.969 10.157l8.738-10.157h-2.071l-7.587 8.819-6.060-8.819h-6.989l9.164 13.336-9.164 10.651h2.071l8.012-9.313 6.4 9.313h6.989l-9.503-13.831z"/></svg>
        </a>
      </div>
    </div>
  </div>

  <button
    id="back-to-top"
    aria-label="Back to top"
    class="fixed bottom-6 right-6 z-40 rounded-full bg-[--color-brand-purple] p-3 text-white shadow-lg opacity-0 pointer-events-none transition-opacity hover:opacity-100"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/></svg>
  </button>
</footer>
