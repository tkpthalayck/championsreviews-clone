---
import BaseLayout from '../layouts/BaseLayout.astro';
import { BASE as base } from '../lib/base';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8 py-24 text-center">
    <p class="text-6xl font-extrabold text-(--color-brand-purple)">404</p>
    <h1 class="mt-4 text-2xl font-bold text-gray-900">We couldn't find that page</h1>
    <p class="mt-2 text-gray-600">It may have been moved or no longer exists.</p>
    <a href={base} class="mt-8 inline-block rounded-lg bg-(--color-brand-purple) px-6 py-3 font-semibold text-white hover:opacity-90 transition-opacity">Back to Home</a>
  </div>
</BaseLayout>
