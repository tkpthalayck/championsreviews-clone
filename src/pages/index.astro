---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import Carousel from '../components/Carousel.astro';
import HeroSlideshow from '../components/HeroSlideshow.astro';
import { BASE as base } from '../lib/base';

const allPosts = (await getCollection('posts')).sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const recent = allPosts.slice(0, 9);

// Re-shuffled on every build (including the daily content-sync's
// auto-triggered rebuild), so the carousel picks a fresh 10 rather than
// always showing the same most-recent posts.
function sampleRandom<T>(items: T[], count: number): T[] {
  const pool = [...items];
  for (let i = pool.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [pool[i], pool[j]] = [pool[j], pool[i]];
  }
  return pool.slice(0, count);
}
const trending = sampleRandom(allPosts, 10);
// A slide with no image is just a blank gradient - only pull from posts
// that actually have one (285 of 295 do).
const heroSlides = sampleRandom(allPosts.filter((p) => p.data.featuredImage), 5);

const categoryCounts = new Map<string, number>();
for (const p of allPosts) {
  for (const c of p.data.categories) categoryCounts.set(c, (categoryCounts.get(c) ?? 0) + 1);
}
const topCategories = [...categoryCounts.entries()].sort((a, b) => b[1] - a[1]).slice(0, 8);
---

<BaseLayout
  title="Discover the Best Picks from Amazon, Walmart & More"
  description="Champions Reviews compares real, well-reviewed products so you can shop with confidence - honest comparisons, buying guides, and the best deals across categories."
>
  {/* The page's one real H1 - kept for SEO/accessibility now that the
      visible hero/search block below is gone (search lives in the header
      only, per request); visually hidden since there's no longer a hero
      banner for it to sit in. */}
  <h1 class="sr-only">Discover the Best Picks from Amazon, Walmart &amp; More</h1>

  {heroSlides.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-6">
      <HeroSlideshow posts={heroSlides} id="hero-slideshow" />
    </section>
  )}

  {trending.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10">
      <h2 class="text-lg font-bold text-gray-900 mb-4">Featured Picks</h2>
      <Carousel posts={trending} id="trending-carousel" />
    </section>
  )}

  {topCategories.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10">
      <h2 class="text-lg font-bold text-gray-900 mb-4">Browse by Category</h2>
      <div class="flex flex-wrap gap-2">
        {topCategories.map(([name]) => (
          <a href={`${base}category/${name.toLowerCase().replace(/[^a-z0-9]+/g, '-')}/`} class="rounded-full border border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 hover:border-(--color-brand-purple) hover:text-(--color-brand-purple) transition-colors">{name}</a>
        ))}
      </div>
    </section>
  )}

  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-16">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xl font-bold text-gray-900">Recently Published</h2>
      <a href={`${base}reviews/`} class="text-sm font-semibold text-(--color-brand-purple) hover:underline">View all &rarr;</a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {recent.map((post) => (
        <PostCard slug={post.data.slug} title={post.data.title} excerpt={post.data.excerpt} date={post.data.date} featuredImage={post.data.featuredImage} categories={post.data.categories} />
      ))}
    </div>
  </section>
</BaseLayout>
