---
// Renders the migrated static WordPress pages (About Us, Privacy Policy,
// Terms, Contacts, etc.) at their original slugs.
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { localizeBody } from '../lib/base';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages.map((page) => ({ params: { slug: page.data.slug }, props: { page } }));
}

const { page } = Astro.props;
const { title, body } = page.data;
---

<BaseLayout title={title} description={`${title} - Champions Reviews`}>
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl font-extrabold text-gray-900 mb-6">{title}</h1>
    <article class="prose prose-purple max-w-none" set:html={localizeBody(body)} />
  </div>
</BaseLayout>
